{
  "extends": [
    "development"
  ],
  "hints": {
    "no-inline-styles": "off",
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "backdrop-filter",
          "scrollbar-width",
          "min-height: auto"
        ]
      }
    ]
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not chrome <= 112",
    "not ios_saf <= 26.4",
    "not safari <= 26.4",
    "not samsung <= 29",
    "not and_ff <= 150",
    "not firefox <= 150",
    "not opera <= 131"
  ]
}